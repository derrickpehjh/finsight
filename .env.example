# ── API Keys ──────────────────────────────────────────────────────────────────
# NewsAPI is optional — leave blank to skip; get a free key at https://newsapi.org/register
NEWSAPI_KEY=
# Reddit is scraped via public JSON endpoints — NO API key or OAuth required

# ── ngrok tunnel (required for public URL) ────────────────────────────────────
NGROK_AUTHTOKEN=your_ngrok_authtoken       # https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_DOMAIN=your-static-domain.ngrok-free.app  # free static domain from ngrok dashboard

# ── Service URLs (auto-filled by docker-compose, override for local dev) ─────
DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsight
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
OLLAMA_URL=http://localhost:11434
