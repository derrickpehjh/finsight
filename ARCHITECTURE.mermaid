flowchart TD
    subgraph Sources["📡 News Sources"]
        S1[Yahoo Finance RSS\nper-ticker feed]
        S2[Benzinga RSS]
        S3[Reuters RSS]
        S4[NewsAPI\nkey required]
        S5[Reddit\npublic JSON]
    end

    subgraph BackendPipeline["⚙️ Backend Pipeline  •  FastAPI :8000"]
        ING["🔄 Ingester\nevery 5 min\n─\ndedup by URL hash\nstores raw articles"]
        PG[("🐘 Postgres :5432\n─\narticles\nticker_sentiment\nwatchlist")]
        PROC["🧠 Processor\ncontinuous\n─\nFinBERT sentiment\nnomic-embed-text\nvectors → Qdrant"]
        QD[("🔷 Qdrant :6333\n─\narticle vectors\nsemantic search")]
        REDIS[("⚡ Redis :6379\n─\nAPI cache 60s TTL\noverview per timeframe")]
        NER["🏷️ NER Service\nextract tickers\nfrom article text"]
        PRICE["💹 Price Fetcher\nyfinance\nprice + momentum_7d"]
        LLM["🦙 Ollama :11434\nllama3.1:8b\nRAG answer gen"]
    end

    subgraph API["🔌 API Routes"]
        R1["/stocks/overview\n?timeframe=1H|4H|1D|1W"]
        R2["/news?ticker=X"]
        R3["/rag/query\nstreaming SSE"]
        R4["/watchlist\nCRUD"]
        R5["/health"]
    end

    subgraph Frontend["🖥️ Next.js Frontend  :3001"]
        PROXY["Next.js Rewrite Proxy\nBACKEND_URL=http://backend:8000"]
        subgraph Views["Chart Views"]
            SC["📊 Scatter Plot\nsentiment × momentum\nbubble = mkt cap"]
            NV["🕸️ Network Graph\nsector clusters\ntop-3 sentiment edges"]
            HV["🌡️ Heatmap\nsentiment grid\nby ticker × time"]
        end
        subgraph Panel["Stock Panel"]
            SUM["📰 Summary Tab\nrecent articles"]
            SIG["📈 Signal Tab\nbull/bear/neutral %\nprice data"]
            RAG["🤖 Analyst Tab\nRAG chat\nstreaming response"]
        end
        WL["📋 Watchlist Sidebar\nadd/remove tickers\nlive prices"]
    end

    subgraph Deployment["🌐 Public Deployment  (optional)"]
        NGROK["ngrok tunnel\nvitalistically-minuscular-jalen\n.ngrok-free.dev"]
    end

    %% Ingestion flow
    S1 & S2 & S3 & S4 & S5 --> ING
    ING --> PG
    PG --> NER
    NER --> PG
    PG --> PROC
    PROC --> QD
    PROC --> PG

    %% API flow
    PRICE --> R1
    PG --> R1
    REDIS <-.->|cache| R1
    PG --> R2
    PG --> R3
    QD --> R3
    R3 --> LLM
    PG --> R4
    REDIS <-.->|bust on\nadd/remove| R4

    %% Frontend flow
    PROXY --> R1 & R2 & R3 & R4 & R5
    Views --> PROXY
    Panel --> PROXY
    WL --> PROXY

    %% Deployment
    NGROK -->|tunnel :3001| PROXY

    %% Styling
    classDef source    fill:#1e3a5f,stroke:#3b82f6,color:#93c5fd
    classDef store     fill:#1a2e1a,stroke:#4ade80,color:#86efac
    classDef service   fill:#2d1b4e,stroke:#a78bfa,color:#c4b5fd
    classDef api       fill:#1c2a1c,stroke:#34d399,color:#6ee7b7
    classDef ui        fill:#1a1a2e,stroke:#818cf8,color:#a5b4fc
    classDef deploy    fill:#2d1f00,stroke:#fbbf24,color:#fde68a

    class S1,S2,S3,S4,S5 source
    class PG,QD,REDIS store
    class ING,PROC,NER,PRICE,LLM service
    class R1,R2,R3,R4,R5 api
    class PROXY,SC,NV,HV,SUM,SIG,RAG,WL ui
    class NGROK deploy
